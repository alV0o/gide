<Window x:Class="gide.Windows.ViewModModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gide.Windows"
        mc:Ignorable="d"
        Title="ViewModModalWindow"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Выберите мод" HorizontalAlignment="Center"/>
        <ListBox MouseDoubleClick="ListBox_MouseDoubleClick" BorderBrush="Transparent" Grid.Row="1" ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}" Width="200"/>
    </Grid>
</Window>
