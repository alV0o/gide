<Page x:Class="gide.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gide.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage"
      DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Button Content="Назад" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="10 5" Click="Back_Click"/>
        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>


            <TextBlock Grid.Row="0" Text="Название"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Game.Title}"/>
            <TextBlock Grid.Row="2" Text="Описание"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Game.Description}"/>
            <TextBlock Grid.Row="4" Text="Ссылка на полный проект"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Game.FullProjectUrl}"/>
            <TextBlock Grid.Row="6" Text="Ссылка на собранный проект"/>
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Game.BuildUrl}"/>
            <TextBlock Grid.Row="8" Text="Название запускаемого файла"/>
            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Game.NameExe}"/>

            <Button Grid.Row="10" Grid.ColumnSpan="2" Content="Сохранить" Click="Save_Click"/>
        </Grid>
    </Grid>
</Page>
