<Page x:Class="gide.Pages.ProjectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gide.Pages"
      xmlns:models="clr-namespace:gide.Models"
      xmlns:converters="clr-namespace:gide.Converters"
      xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProjectPage"
      DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Page.Resources>
        <converters:DirsAndFilesConverter x:Key="DirsConverter"/>
    </Page.Resources>
    <Grid>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TreeView Grid.RowSpan="2" Margin="10" ItemsSource="{Binding MainDirectory}" TreeView.SelectedItemChanged="treeview1_SelectedItemChanged">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type models:DirectoryClass}">
                    <HierarchicalDataTemplate.ItemsSource>
                        <MultiBinding Converter="{StaticResource DirsConverter}">
                            <Binding Path="Files"/>
                            <Binding Path="Directories"/>
                        </MultiBinding>
                    </HierarchicalDataTemplate.ItemsSource>
                    <TextBlock Text="{Binding Name}"/>
                </HierarchicalDataTemplate>

                <DataTemplate DataType="{x:Type models:FileClass}">
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
        <avalonedit:TextEditor x:Name="avalonedit" Grid.Column="1" Grid.Row="1" Margin="10" Document="{Binding TextEdit}"/>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
            <Button Content="Назад" Click="BackBtn_Click"/>
            <Button Content="Сохранить" Click="SaveBtn_Click"/>
            <Button Content="Собрать" Click="BuildBtn_Click"/>
            <Button Content="Запустить" Click="Start_Click"/>
        </StackPanel>
    </Grid>
</Page>
