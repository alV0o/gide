<Page x:Class="gide.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gide.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage"
      DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Grid>
        <Border CornerRadius="10" Background="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Width="200" Margin="20">
                <TextBlock FontSize="24" Text="Логин"/>
                <TextBox FontSize="24" Text="{Binding Username}"/>
                <TextBlock FontSize="24" Text="Пароль"/>
                <TextBox FontSize="24" Text="{Binding Password}"/>
                <Button FontSize="24" Content="Войти" Click="Login_Btn"/>
                <Button Click="Reg_Click" BorderBrush="Transparent" Content="Зарегистрироваться" HorizontalAlignment="Right" Background="Transparent"/>
                <Button Click="AuthorLogin_Click" BorderBrush="Transparent" Content="Войти как автор" HorizontalAlignment="Right" Background="Transparent"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
